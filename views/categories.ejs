<h1><%= title %></h1>
<ul>
  <% if (locals.categories && categories.length > 0) { %>
    <% categories.forEach(category => { %>
      <li>
        <!-- Envolvemos el nombre en un enlace usando su id -->
        <a href="/categories/<%= category.category_id %>"><%= category.name %></a>
      </li>
    <% }); %>
  <% } else { %>
    <li>No hay categorías disponibles.</li>
  <% } %>
</ul>
